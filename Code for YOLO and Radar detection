def build_static_radar():
    surf = pygame.Surface((WIN_W, WIN_H), pygame.SRCALPHA)

    for rr in range(RAD, 0, -1):
        if rr % 14 != 0:
            continue
        t = rr / RAD
        shade = int(lerp(16, 10, 1 - t))
        pygame.gfxdraw.filled_circle(surf, RCX, RCY, rr, (shade, shade + 3, shade + 7, 255))

    for ring in range(1, 6):
        r  = int(RAD * ring / 5)
        rm = MAX_RANGE_M * ring / 5
        is_outer = ring == 5
        col   = RING_MAIN if is_outer else GRID_LINE
        alpha = 235 if is_outer else 120
        pygame.gfxdraw.aacircle(surf, RCX, RCY, r, (*col, alpha))
        lbl = font_tiny.render(f"{rm:.0f} m", True, (*TEXT_TERT, 255))
        surf.blit(lbl, (RCX + r - lbl.get_width() - 6, RCY - lbl.get_height() - 3))

    for frac in (0.2, 0.4, 0.6, 0.8):
        draw_dashed_circle(surf, (*GRID_LINE_2, 160), RCX, RCY, int(RAD * frac))

    for deg in range(0, 360, 30):
        a      = math.radians(deg - 90)
        is_maj = deg % 90 == 0
        col    = GRID_LINE if is_maj else GRID_LINE_2
        alpha  = 140 if is_maj else 70
        ex = int(RCX + RAD * math.cos(a))
        ey = int(RCY + RAD * math.sin(a))
        pygame.draw.line(surf, (*col, alpha), (RCX, RCY), (ex, ey), 1)

    for deg, lbl_str in [(0, "N"), (90, "E"), (180, "S"), (270, "W")]:
        a  = math.radians(deg - 90)
        lx = int(RCX + (RAD + 22) * math.cos(a))
        ly = int(RCY + (RAD + 22) * math.sin(a))
        t  = font_small.render(lbl_str, True, (*TEXT_SEC, 255))
        surf.blit(t, (lx - t.get_width() // 2, ly - t.get_height() // 2))

    fov_pts = [
        (int(RCX + (RAD + 13) * math.cos(math.radians(d - 90))),
         int(RCY + (RAD + 13) * math.sin(math.radians(d - 90))))
        for d in range(-60, 61, 2)
    ]
    pygame.draw.lines(surf, (*ACCENT_DIM, 150), False, fov_pts, 1)

    for deg in range(-60, 61, 15):
        a = math.radians(deg - 90)
        is_maj = deg % 30 == 0
        r0 = RAD + 11
        r1 = RAD + (22 if is_maj else 15)
        pygame.draw.line(
            surf, (*ACCENT, 170 if is_maj else 70),
            (int(RCX + r0 * math.cos(a)), int(RCY + r0 * math.sin(a))),
            (int(RCX + r1 * math.cos(a)), int(RCY + r1 * math.sin(a))), 1
        )
        if is_maj:
            lbl_str = f"{deg:+d}°" if deg != 0 else "0°"
            lbl_img = font_tiny.render(lbl_str, True, (*TEXT_TERT, 255))
            lx = int(RCX + (RAD + 36) * math.cos(a)) - lbl_img.get_width() // 2
            ly = int(RCY + (RAD + 36) * math.sin(a)) - lbl_img.get_height() // 2
            surf.blit(lbl_img, (lx, ly))

    pr_r = int(RAD * (PRIORITY_RANGE_M / MAX_RANGE_M))
    pygame.gfxdraw.aacircle(surf, RCX, RCY, pr_r, (*ACCENT, 90))
    draw_dashed_circle(surf, (*ACCENT, 60), RCX, RCY, pr_r, dash=4, gap=6)

    pygame.gfxdraw.aacircle(surf, RCX, RCY, RAD,     (*RING_MAIN, 235))
    pygame.gfxdraw.aacircle(surf, RCX, RCY, RAD + 1, (*RING_MAIN,  60))

    return surf

