        rounded_rect(screen, (CAM_X + 18, inner_y, inner_w, inner_h), BORDER, radius=12, width=1)
        msg = font_body.render("Waiting for camera feed…", True, TEXT_SEC)
        screen.blit(msg, (CAM_X + 18 + inner_w // 2 - msg.get_width() // 2,
                           inner_y + inner_h // 2 - msg.get_height() // 2))
        return False

    annotated = frame.copy()

    # --- YOLO boxes ---
    for d in dets:
        color = (0, 255, 0)
        if d["cam_dist"] is not None:
            if d["cam_dist"] < 1:
                color = (0, 0, 255)
            elif d["cam_dist"] < 2:
                color = (0, 165, 255)
        text = d["label"]
        if d["cam_dist"] is not None:
            text += f' {d["cam_dist"]:.2f}m'
        cv2.rectangle(annotated, (d["x1"], d["y1"]), (d["x2"], d["y2"]), color, 2)
        cv2.putText(annotated, text, (d["x1"], d["y1"] - 10),
                    cv2.FONT_HERSHEY_SIMPLEX, 0.5, color, 2)

    # --- Radar fusion lines projected onto camera pixel space ---
    for i, t in enumerate(radar_snapshot):
        px = angle_to_cam_pixel_x(t.angle_deg)
        confirmed = any(d["x1"] <= px <= d["x2"] for d in dets)
        color = (0, 255, 255) if confirmed else (220, 90, 232)  # BGR-ish yellow / magenta
        label = "RADAR+CAM" if confirmed else "RADAR-ONLY"
        cv2.line(annotated, (px, 0), (px, CAM_H), color, 1)
        cv2.putText(annotated, f'{label} {t.dist_m:.2f}m',
                    (min(px + 5, CAM_W - 160), 20 + 20 * i),
                    cv2.FONT_HERSHEY_SIMPLEX, 0.45, color, 2)

    # Convert BGR (OpenCV) -> RGB, transpose for pygame, scale into panel
    rgb = cv2.cvtColor(annotated, cv2.COLOR_BGR2RGB)
    rgb = np.transpose(rgb, (1, 0, 2))
    cam_surface = pygame.surfarray.make_surface(rgb)
    cam_surface = pygame.transform.smoothscale(cam_surface, (inner_w, inner_h))

    screen.blit(cam_surface, (CAM_X + 18, inner_y))
    rounded_rect(screen, (CAM_X + 18, inner_y, inner_w, inner_h), BORDER, radius=12, width=1)
    return True

