# ─────────────────────────────────────────────
#  MAIN LOOP
# ─────────────────────────────────────────────
pg_running = True
_last_radar_t = time.time()

while pg_running:
    clock.tick(FPS)
    now = time.time()

    for event in pygame.event.get():
        if event.type == pygame.QUIT:
            pg_running = False
        elif event.type == pygame.KEYDOWN and event.key == pygame.K_ESCAPE:
            pg_running = False

    # ── Read radar frame ─────────────────────
    if radar is not None and not radar.frame_buffer.empty():
        frame = radar.frame_buffer.get()
        raw   = np.frombuffer(frame, dtype=np.uint16)
        frame_no += 1
        objects_raw = []

        _now_radar = time.time()
        _dt_radar = _now_radar - _last_radar_t
        if _dt_radar > 0:
            radar_fps = 1.0 / _dt_radar
        _last_radar_t = _now_radar

        try:
            magnitude = process_radar_cube(raw, setting_data)
            magnitude[:, :5] = 0
            update_range_profile(magnitude)

            threshold  = np.max(magnitude) * 0.45
            sorted_idx = np.argsort(magnitude.flatten())[::-1]
            count      = 0

            for idx in sorted_idx:
                if count >= MAX_TARGETS:
                    break
                ci, ri = np.unravel_index(idx, magnitude.shape)
                if magnitude[ci, ri] < threshold:
                    break
                dist_m = ri * range_res
                if dist_m < 0.3 or dist_m > PRIORITY_RANGE_M:
                    continue
                angle_deg = (ci - num_chirps / 2) * (RADAR_FOV_DEG / num_chirps)
                rad_a     = math.radians(angle_deg)
                px_ = int(RCX + dist_m * (RAD / MAX_RANGE_M) * math.sin(rad_a))
                py_ = int(RCY - dist_m * (RAD / MAX_RANGE_M) * math.cos(rad_a))

                if any(abs(px_ - ox) < 22 and abs(py_ - oy) < 22 for ox, oy, *_ in objects_raw):
                    continue

                energy_norm = min(1.0, magnitude[ci, ri] / (np.max(magnitude) + 1e-9))
                objects_raw.append((px_, py_, dist_m, angle_deg, energy_norm))
                count += 1

        except Exception as e:
            print("Processing error:", e)

        matched     = set()
        new_targets = {}
        for (px_, py_, dm, ad, en) in objects_raw:
            best_id, best_d = None, 45
            for tid, t in targets.items():
                if tid in matched:
                    continue
                d = math.hypot(px_ - t.px, py_ - t.py)
                if d < best_d:
                    best_d, best_id = d, tid
            if best_id is not None:
                targets[best_id].update(px_, py_, dm, ad, en)
                new_targets[best_id] = targets[best_id]
                matched.add(best_id)
            else:
                nt = Target(px_, py_, dm, ad, en)
                new_targets[nt.id] = nt
        for tid, t in targets.items():
            if tid not in new_targets and not t.stale():
                new_targets[tid] = t
        targets = new_targets

    # ── Snapshot YOLO detections + active radar targets for fusion drawing ──
    with lock:
        dets_snapshot = list(yolo_detections)
    active_targets = [t for t in targets.values() if not t.stale()]

    # ── Render ───────────────────────────────
    screen.fill(BG)

    cam_alive = draw_camera_panel(dets_snapshot, active_targets)
    draw_radar_dynamic(now)
    draw_sidebar(now)
    draw_topbar(now, cam_alive)
    draw_bottombar(now)

    pygame.display.flip()

# ── Cleanup ──────────────────────────────────
running = False
if radar is not None:
    try:
        radar.stop()
    except Exception:
        pass
cam_proc.terminate()
pygame.quit()
