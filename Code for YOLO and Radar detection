#  HELPERS
# ─────────────────────────────────────────────
def lerp(a, b, t):
    return a + (b - a) * max(0.0, min(1.0, t))

def lerp_color(c1, c2, t):
    t = max(0.0, min(1.0, t))
    return tuple(int(c1[i] + (c2[i] - c1[i]) * t) for i in range(3))

def signal_color(energy):
    if energy < 0.5:
        return lerp_color(SIG_LOW, SIG_MID, energy / 0.5)
    return lerp_color(SIG_MID, SIG_HIGH, (energy - 0.5) / 0.5)

def fill_aa_circle(surf, color, cx, cy, r):
    if r <= 0:
        return
    pygame.gfxdraw.filled_circle(surf, cx, cy, r, color)
    pygame.gfxdraw.aacircle(surf, cx, cy, r, color)

def draw_dashed_circle(surf, color, cx, cy, r, dash=5, gap=6):
    if r <= 0:
        return
    circ  = 2 * math.pi * r
    total = dash + gap
    steps = max(1, int(circ / total))
    for i in range(steps):
        a0  = 2 * math.pi * i * total / circ
        a1  = 2 * math.pi * (i * total + dash) / circ
        pts = [(int(cx + r * math.cos(t)), int(cy + r * math.sin(t)))
               for t in np.linspace(a0, a1, 6)]
        if len(pts) >= 2:
            pygame.draw.lines(surf, color, False, pts, 1)

def range_zone(dist_m):
    if dist_m < 1.5:
        return "NEAR"
    if dist_m < 3.0:
        return "MID"
    return "FAR"

def zone_color(zone):
    return {"NEAR": DANGER, "MID": WARNING, "FAR": SUCCESS}[zone]

def rounded_rect(surf, rect, color, radius=8, width=0):
    pygame.draw.rect(surf, color, rect, width, border_radius=radius)

# ─────────────────────────────────────────────
#  TARGET TRACKER
# ─────────────────────────────────────────────
class Target:
    _next_id = 1

    def __init__(self, px, py, dist_m, angle_deg, energy):
        self.id        = Target._next_id
        Target._next_id += 1
        self.px        = px
        self.py        = py
        self.dist_m    = dist_m
        self.angle_deg = angle_deg
        self.energy    = energy
        self.last_seen = time.time()
        self.trail     = [(px, py)]
        self.lock_anim = 0.25

    def update(self, px, py, dist_m, angle_deg, energy):
        self.trail.append((px, py))
        if len(self.trail) > 24:
            self.trail.pop(0)
        self.px, self.py        = px, py
        self.dist_m, self.angle_deg = dist_m, angle_deg
        self.energy              = energy
        self.last_seen           = time.time()
        self.lock_anim           = min(1.0, self.lock_anim + 0.06)

    def stale(self):
        return time.time() - self.last_seen > 2.5

