def process_radar_cube(raw_data, setting_data):
    num_rx      = int(setting_data.get("num_rx_antennas",      3))
    num_chirps  = int(setting_data.get("num_chirps_per_frame", 16))
    num_samples = int(setting_data.get("num_samples_per_chirp", 64))
    expected    = num_rx * num_chirps * num_samples
    data        = raw_data[:expected].astype(np.float32) - 2048.0
    if data.size < expected:
        raise ValueError("Frame too small")
    cube      = data.reshape(num_rx, num_chirps, num_samples)
    range_fft = np.fft.rfft(cube, axis=2)
    magnitude = np.abs(range_fft).mean(axis=0)
    return magnitude

