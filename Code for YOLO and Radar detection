def update_range_profile(magnitude):
    global rp_latest
    rp_latest = magnitude.max(axis=0)

def draw_range_profile(surf, x, y):
    rp_surf.fill(PANEL_BG2)

    for m in range(1, 6):
        gx = int((m / MAX_RANGE_M) * RP_W)
        pygame.draw.line(rp_surf, GRID_LINE, (gx, 0), (gx, RP_H - 14), 1)

    bins = len(rp_latest)
    pts  = []
    peak = max(rp_latest.max(), 1.0)
    for b in range(bins):
        px_ = int(b / bins * RP_W)
        amp = rp_latest[b] / peak
        py_ = int((RP_H - 16) - amp * (RP_H - 22))
        pts.append((px_, py_))

    if len(pts) >= 2:
        fill_pts = [(0, RP_H - 14)] + pts + [(RP_W - 1, RP_H - 14)]
        fill_s   = pygame.Surface((RP_W, RP_H), pygame.SRCALPHA)
        pygame.draw.polygon(fill_s, (*ACCENT, 30), fill_pts)
        rp_surf.blit(fill_s, (0, 0))
        pygame.draw.lines(rp_surf, ACCENT_GLOW, False, pts, 2)

    for t in targets.values():
        if t.stale():
            continue
        bx = int((t.dist_m / MAX_RANGE_M) * RP_W)
        pygame.draw.line(rp_surf, WARNING, (bx, 0), (bx, RP_H - 14), 1)
        lbl = font_tiny.render(f"T{t.id}", True, WARNING)
        rp_surf.blit(lbl, (min(bx + 3, RP_W - lbl.get_width() - 2), 2))

    for m in range(0, 6):
        gx = int((m / MAX_RANGE_M) * RP_W)
        lbl = font_tiny.render(f"{m}m", True, TEXT_TERT)
        lx = min(max(gx - lbl.get_width() // 2, 0), RP_W - lbl.get_width())
        rp_surf.blit(lbl, (lx, RP_H - 12))

    surf.blit(rp_surf, (x, y))
    rounded_rect(surf, (x, y, RP_W, RP_H), BORDER, radius=8, width=1)

