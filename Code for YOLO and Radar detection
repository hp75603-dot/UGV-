def capture_thread():
    global latest_frame
    while running:
        raw = cam_proc.stdout.read(FRAME_SIZE)
        if len(raw) != FRAME_SIZE:
            if not running:
                break
            continue
        yuv = np.frombuffer(raw, dtype=np.uint8).reshape((int(CAM_H * 1.5), CAM_W))
        frame = cv2.cvtColor(yuv, cv2.COLOR_YUV2BGR_I420)
        with lock:
            latest_frame = frame


# ─────────────────────────────────────────────
#  YOLO INFERENCE THREAD
# ─────────────────────────────────────────────
def inference_thread():
    global yolo_detections, yolo_fps
    last_t = time.time()
    while running:
        with lock:
            frame = latest_frame.copy() if latest_frame is not None else None
        if frame is None:
            time.sleep(0.01)
            continue

        results = model(frame, imgsz=256, conf=0.4, verbose=False)
        dets = []
        for r in results:
            names = r.names
            for box in r.boxes:
                cls_id = int(box.cls[0])
                label = names[cls_id]
                conf = float(box.conf[0])
                x1, y1, x2, y2 = map(int, box.xyxy[0])
                pixel_width = x2 - x1
                cam_dist = None
                if label in KNOWN_WIDTHS and pixel_width > 0:
                    cam_dist = (KNOWN_WIDTHS[label] * FOCAL_LENGTH) / pixel_width
                dets.append({
                    "label": label, "x1": x1, "y1": y1, "x2": x2, "y2": y2,
                    "cam_dist": cam_dist, "conf": conf,
                })

        # Keep only the top MAX_YOLO_DETECTIONS by confidence
        dets.sort(key=lambda d: d["conf"], reverse=True)
        dets = dets[:MAX_YOLO_DETECTIONS]

        now_t = time.time()
        dt = now_t - last_t
        if dt > 0:
            yolo_fps = 1.0 / dt
        last_t = now_t

        with lock:
            yolo_detections = dets
        time.sleep(0.001)


def angle_to_cam_pixel_x(angle_deg):
    half_fov = CAMERA_HFOV_DEG / 2
    frac = (angle_deg + half_fov) / CAMERA_HFOV_DEG
    frac = min(max(frac, 0.0), 1.0)
    return int(frac * CAM_W)


