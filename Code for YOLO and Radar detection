def draw_target_card(t, x, y, w):
    h = 116
    zone = range_zone(t.dist_m)
    zcol = zone_color(zone)
    xm = t.dist_m * math.sin(math.radians(t.angle_deg))
    ym = t.dist_m * math.cos(math.radians(t.angle_deg))

    rounded_rect(screen, (x, y, w, h), PANEL_BG2, radius=12)
    rounded_rect(screen, (x, y, w, h), BORDER, radius=12, width=1)

    fill_aa_circle(screen, zcol, x + 18, y + 20, 4)
    id_txt = font_body_b.render(f"Target {t.id:02d}", True, TEXT_PRI)
    screen.blit(id_txt, (x + 28, y + 13))

    badge_txt = font_tiny.render(zone, True, zcol)
    bw = badge_txt.get_width() + 16
    bh = badge_txt.get_height() + 6
    bx = x + w - bw - 14
    by = y + 12
    rounded_rect(screen, (bx, by, bw, bh), (*zcol, 22), radius=bh // 2)
    rounded_rect(screen, (bx, by, bw, bh), (*zcol, 90), radius=bh // 2, width=1)
    screen.blit(badge_txt, (bx + 8, by + 3))

    pygame.draw.line(screen, BORDER_SOFT, (x + 16, y + 42), (x + w - 16, y + 42), 1)

    col_w = (w - 32) // 2
    metrics = [
        ("RANGE",    f"{t.dist_m:.2f} m",   TEXT_PRI,    font_metric),
        ("AZIMUTH",  f"{t.angle_deg:+.1f}°", ACCENT_GLOW, font_metric),
        ("X OFFSET", f"{xm:+.2f} m",         TEXT_SEC,    font_metric_s),
        ("Y DEPTH",  f"{ym:.2f} m",          TEXT_SEC,    font_metric_s),
    ]
    for i, (lbl, val, vcol, vfont) in enumerate(metrics):
        col_i, row_i = i % 2, i // 2
        mx = x + 16 + col_i * col_w
        my = y + 50 + row_i * 32
        lbl_img = font_tiny.render(lbl, True, TEXT_TERT)
        val_img = vfont.render(val, True, vcol)
        screen.blit(lbl_img, (mx, my))
        screen.blit(val_img, (mx, my + 13))

    bar_y = y + h - 16
    sig_col = signal_color(t.energy)
    lbl_img = font_tiny.render("SIGNAL", True, TEXT_TERT)
    pct_img = font_tiny.render(f"{int(t.energy * 100)}%", True, sig_col)
    screen.blit(lbl_img, (x + 16, bar_y - 13))
    screen.blit(pct_img, (x + w - 16 - pct_img.get_width(), bar_y - 13))

    bar_x, bar_w, bar_h = x + 16, w - 32, 5
    rounded_rect(screen, (bar_x, bar_y, bar_w, bar_h), BORDER_SOFT, radius=3)
    fill_w = max(4, int(bar_w * t.energy))
    rounded_rect(screen, (bar_x, bar_y, fill_w, bar_h), sig_col, radius=3)

    return h

