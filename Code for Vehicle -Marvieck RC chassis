  if (k==='x') { keyHeld['x']=false; release('B'); }
  if (k==='a') { keyHeld['a']=false; release('L'); }
  if (k==='d') { keyHeld['d']=false; release('R'); }
  if (k==='q') { keyHeld['q']=false; release('FL'); }
  if (k==='e') { keyHeld['e']=false; release('FR'); }
});

