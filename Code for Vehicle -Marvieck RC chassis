<script>
var spd = 0;
var activeCmd = null;
var sending   = false;

var SPEED_CLASSES = ['active-slow','active-medium','active-high','active-ultra'];

function setSpd(level) {
  spd = level;
  for (var i = 0; i < 4; i++) {
    var el = document.getElementById('sp' + i);
    el.className = 'spd';
    if (i === level) el.className = 'spd ' + SPEED_CLASSES[level];
  }
  cmd('SPD');
}

function hold(c) {
  activeCmd = c;
  document.getElementById('b' + (c==='F'?'F':c==='B'?'B':c==='L'?'L':c==='R'?'R':c==='FL'?'FL':'FR')).classList.add('held');
  sendActive();
}
function release(c) {
  activeCmd = null;
  try { document.getElementById('b' + (c==='F'?'F':c==='B'?'B':c==='L'?'L':c==='R'?'R':c==='FL'?'FL':'FR')).classList.remove('held'); } catch(e){}
  // on release: if it was throttle, stop drive; if steering only, centre
  if (c === 'L' || c === 'R') {
    cmd('C');
  } else {
    cmd('S');
  }
}

function sendActive() {
  if (!activeCmd) return;
  cmd(activeCmd);
  // keep sending while held for reliability
  setTimeout(function(){ if (activeCmd) sendActive(); }, 150);
}

function cmd(c) {
  if (sending) return;
  sending = true;
  fetch('/cmd?v=' + c + '&spd=' + spd)
    .then(function(r){ return r.json(); })
    .then(function(j){
      document.getElementById('sDrive').innerText = j.drive;
      document.getElementById('sSteer').innerText = j.steer;
      document.getElementById('sSpeed').innerText = j.sname;
      document.getElementById('sPwm').innerText   = j.pwm;
      sending = false;
    }).catch(function(){ sending = false; });
}

// keyboard
var keyHeld = {};
document.addEventListener('keydown', function(e) {
  if (e.repeat) return;
  var k = e.key.toLowerCase();
  if (k==='w' && !keyHeld['w']) { keyHeld['w']=true; hold('F'); }
  if (k==='x' && !keyHeld['x']) { keyHeld['x']=true; hold('B'); }
  if (k==='a' && !keyHeld['a']) { keyHeld['a']=true; hold('L'); }
  if (k==='d' && !keyHeld['d']) { keyHeld['d']=true; hold('R'); }
  if (k==='q' && !keyHeld['q']) { keyHeld['q']=true; hold('FL'); }
  if (k==='e' && !keyHeld['e']) { keyHeld['e']=true; hold('FR'); }
  if (k==='s') cmd('S');
  if (k==='1') setSpd(0);
  if (k==='2') setSpd(1);
  if (k==='3') setSpd(2);
  if (k==='4') setSpd(3);
});
