void setup() {
  Serial.begin(115200);

  esc.attach(ESC_PIN,   1000, 2000);
  steer.attach(SERVO_PIN, 1000, 2000);

  Serial.println("ESC calibrating...");
  esc.writeMicroseconds(2000);
  delay(2000);
  esc.writeMicroseconds(1000);
  delay(2000);
  esc.writeMicroseconds(ESC_STOP);
  steer.writeMicroseconds(STEER_CENTRE);
  delay(2000);
  Serial.println("ESC ready");

  WiFi.beginAP(AP_SSID, AP_PASS);
  delay(1000);
  server.begin();

  Serial.println("Connect to: UGV-Control / harsh1234");
  Serial.println("Open browser: http://192.168.4.1");
}

void loop() {
  WiFiClient client = server.available();
  if (!client) return;

  String req = "";
  while (client.connected()) {
    if (client.available()) {
      char c = client.read();
      req += c;
      if (req.endsWith("\r\n\r\n")) break;
    }
  }

  if (req.indexOf("GET / ") >= 0) {
    client.println("HTTP/1.1 200 OK");
    client.println("Content-Type: text/html");
    client.println("Connection: close");
    client.println();
    for (int i = 0; i < (int)strlen_P(HTML); i++)
      client.print((char)pgm_read_byte(HTML + i));
    client.stop();
    return;
  }

  if (req.indexOf("GET /cmd") >= 0) {

    int vIdx = req.indexOf("v=");
    String cmd = "";
    if (vIdx >= 0) {
      int endIdx = req.indexOf('&', vIdx);
      if (endIdx < 0) endIdx = req.indexOf(' ', vIdx);
      cmd = req.substring(vIdx + 2, endIdx);
    }

    int sIdx = req.indexOf("spd=");
    int level = 0;
    if (sIdx >= 0) {
      level = constrain(req.charAt(sIdx + 4) - '0', 0, 3);
    }

    int escPwm   = ESC_STOP;
    int steerPwm = STEER_CENTRE;
    String drv   = "STOP";
    String str   = "CENTRE";

    if      (cmd == "F")   { escPwm=FWD_SPEEDS[level]; steerPwm=STEER_CENTRE; drv="FWD";  str="CENTRE"; }
    else if (cmd == "B")   { escPwm=REV_SPEEDS[level]; steerPwm=STEER_CENTRE; drv="REV";  str="CENTRE"; }
    else if (cmd == "FL")  { escPwm=FWD_SPEEDS[level]; steerPwm=STEER_LEFT;   drv="FWD";  str="LEFT";   }
    else if (cmd == "FR")  { escPwm=FWD_SPEEDS[level]; steerPwm=STEER_RIGHT;  drv="FWD";  str="RIGHT";  }
    else if (cmd == "L")   { escPwm=ESC_STOP;          steerPwm=STEER_LEFT;   drv="STOP"; str="LEFT";   }
    else if (cmd == "R")   { escPwm=ESC_STOP;          steerPwm=STEER_RIGHT;  drv="STOP"; str="RIGHT";  }
    else if (cmd == "C")   { escPwm=ESC_STOP;          steerPwm=STEER_CENTRE; drv="STOP"; str="CENTRE"; }
    else if (cmd == "S")   { escPwm=ESC_STOP;          steerPwm=STEER_CENTRE; drv="STOP"; str="CENTRE"; }
    else if (cmd == "SPD") { escPwm=ESC_STOP;          steerPwm=STEER_CENTRE; drv="STOP"; str="CENTRE"; }

    esc.writeMicroseconds(escPwm);
    steer.writeMicroseconds(steerPwm);

    String json = "{\"drive\":\"" + drv +
                  "\",\"steer\":\"" + str +
                  "\",\"sname\":\"" + String(SPEED_NAMES[level]) +
                  "\",\"pwm\":" + String(escPwm) + "}";

    client.println("HTTP/1.1 200 OK");
    client.println("Content-Type: application/json");
    client.println("Connection: close");
    client.println();
    client.println(json);
    client.stop();
    return;
  }

  client.println("HTTP/1.1 404 Not Found");
  client.println("Connection: close");
  client.println();
  client.stop();
}
